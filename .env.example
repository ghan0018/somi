# SOMI Connect
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/somi_dev
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# AWS
AWS_REGION=us-east-1
AWS_S3_LIBRARY_BUCKET=somi-library-media-dev
AWS_S3_PATIENT_BUCKET=somi-patient-media-dev

# Datadog (optional for local dev)
DD_SERVICE=somi-connect
DD_ENV=development
